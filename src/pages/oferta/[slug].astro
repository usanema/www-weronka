---
import Layout from '../../layouts/Layout.astro';
import { Button } from '../../components/Button';
import PocketBase from 'pocketbase';

export async function getStaticPaths() {
  const pb = new PocketBase('http://srv50.mikr.us:30154');
  try {
    const records = await pb.collection('services').getFullList({ sort: 'order' });
    
    return records.map((record) => ({
      params: { slug: record.slug },
      props: { 
        service: record
      },
    }));
  } catch (e) {
    console.error("Error generating static paths:", e);
    return [];
  }
}

const { service } = Astro.props;
const imageUrl = service.image 
  ? `http://srv50.mikr.us:30154/api/files/services/${service.id}/${service.image}` 
  : "https://images.unsplash.com/photo-1531983412531-1f49a365ffed?q=80&w=2000&auto=format&fit=crop";
---

<Layout title={service.title}>
  <div class="pt-28 md:pt-36 pb-12 md:pb-16 rounded-t-none md:rounded-t-[3rem]" style={`background-color: ${service.card_color || '#BEDBF4'}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto slide-up">
        <span class="inline-block py-1 px-3 rounded-full bg-primary/20 text-primary font-semibold text-sm mb-4">Moja Oferta</span>
        <h1 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6 text-gray-900 px-4">{service.title}</h1>
        <p class="text-lg md:text-xl text-gray-600 px-4">
          {service.short_description}
        </p>
      </div>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {imageUrl && (
        <div class="mb-12 slide-up">
          <img src={imageUrl} alt={service.title} class="w-full h-auto max-h-[500px] object-cover rounded-[2rem] shadow-xl" />
        </div>
      )}

      <div class="prose prose-lg prose-pink max-w-none text-gray-700 mb-16 slide-up" set:html={service.content} />

      <div class="bg-secondary/10 rounded-3xl p-10 flex flex-col md:flex-row items-center justify-between gap-8 slide-up">
        <div>
          <h3 class="text-2xl font-bold mb-2">Chcesz dowiedzieć się więcej?</h3>
          <p class="text-gray-600">Umów się na pierwsze, bezpłatne spotkanie poznawcze, podczas którego sprawdzimy, czy jestem doulą dla Ciebie.</p>
        </div>
        <Button href="/kontakt">Napisz do mnie</Button>
      </div>
    </div>
  </section>
</Layout>
