---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/Button';
import PocketBase from 'pocketbase';

const pb = new PocketBase('https://pocketbase.bieda.it');
let pageData = null;
let settings = null;

try {
  const records = await pb.collection('contact_page').getList(1, 1);
  if (records.items.length > 0) pageData = records.items[0];
  
  const setRecords = await pb.collection('site_settings').getList(1, 1);
  if (setRecords.items.length > 0) settings = setRecords.items[0];
} catch (e) {
  console.error("PocketBase connection error in kontakt:", e.message);
}

const title = pageData?.title || "Porozmawiajmy";
const subtitle = pageData?.subtitle || "Masz pytania? Chcesz umówić się na niezobowiązujące spotkanie? Napisz do mnie. Odpowiadam najszybciej jak to możliwe!";
const workingArea = pageData?.working_area || "<p>Warszawa i okolice do 30km.<br/>Konsultacje i spotkania możliwe również online.</p>";

const phone = settings?.phone || "+48 123 456 789";
const email = settings?.email || "kontakt@weronikanowik.pl";
const ig = settings?.instagram_link || "#";
const fb = settings?.facebook_link || "#";
---

<Layout title="Kontakt">
  <div class="pt-28 md:pt-36 pb-12 md:pb-16 bg-gray-50 rounded-t-none md:rounded-t-[3rem]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto slide-up">
        <h1 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6 text-gray-900">{title}</h1>
        <p class="text-lg md:text-xl text-gray-600 px-4">
          {subtitle}
        </p>
      </div>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Dane kontaktowe -->
        <div class="slide-up">
          <h2 class="text-3xl font-bold mb-8">Dane Kontaktowe</h2>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4 text-primary">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <p class="font-bold text-gray-900">Telefon</p>
                <p class="text-gray-600">{phone}</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4 text-primary">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="font-bold text-gray-900">E-mail</p>
                <p class="text-gray-600">{email}</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-primary/10 p-3 rounded-full mr-4 text-primary">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div>
                <p class="font-bold text-gray-900">Obszar działania</p>
                <div class="text-gray-600 prose prose-sm max-w-none prose-p:m-0" set:html={workingArea}></div>
              </div>
            </div>
          </div>

          <div class="mt-12">
            <h3 class="text-xl font-bold mb-4">Śledź mnie na bieżąco:</h3>
            <div class="flex space-x-4">
              <a href={ig} target="_blank" class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center text-gray-600 hover:bg-primary hover:text-white transition-colors">
                IG
              </a>
              <a href={fb} target="_blank" class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center text-gray-600 hover:bg-primary hover:text-white transition-colors">
                FB
              </a>
            </div>
          </div>
        </div>

        <!-- Formularz -->
        <div class="bg-white rounded-3xl shadow-xl p-8 border border-gray-100 slide-up" style="animation-delay: 0.2s">
          <form class="space-y-6" onsubmit="event.preventDefault(); alert('Formularz został wysłany (wersja demo)!');">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Twoje imię</label>
              <input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="Wpisz imię..." required>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Adres e-mail</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="twoj@email.com" required>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Temat</label>
              <select id="subject" name="subject" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow">
                <option>Wsparcie okołoporodowe</option>
                <option>Konsultacja</option>
                <option>Zapisy na grupy / warsztaty</option>
                <option>Inne pytanie</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Wiadomość</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow" placeholder="Napisz, w czym mogę Ci pomóc..." required></textarea>
            </div>

            <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-full font-medium text-white bg-primary hover:bg-opacity-90 transition-colors shadow-lg hover:shadow-primary/30">
              Wyślij wiadomość
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>
</Layout>
