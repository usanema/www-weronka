---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/Button';
import PocketBase from 'pocketbase';

const pb = new PocketBase('https://pocketbase.bieda.it');
let pageData = null;

try {
  const records = await pb.collection('about_page').getList(1, 1);
  if (records.items.length > 0) {
    pageData = records.items[0];
  }
} catch (e) {
  console.error("PocketBase connection error in o-mnie:", e.message);
}

const title = pageData?.title || "Kilka słów o mnie";
const subtitle = pageData?.subtitle || "Poznaj moją historię i dowiedz się, dlaczego zdecydowałam się towarzyszyć kobietom w jednej z najważniejszych podróży ich życia.";
const content = pageData?.content || "<p>Moja droga do bycia doulą...</p>";
const heroImage = pageData?.hero_image 
  ? `https://pocketbase.bieda.it/api/files/about_page/${pageData.id}/${pageData.hero_image}`
  : "https://images.unsplash.com/photo-1555252834-8c80fb619208?q=80&w=1000&auto=format&fit=crop";

---

<Layout title="O mnie">
  <div class="pt-28 md:pt-36 pb-12 md:pb-16 bg-secondary/10 rounded-t-none md:rounded-t-[3rem]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto slide-up">
        <h1 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6 px-4">{title}</h1>
        <p class="text-lg md:text-xl text-gray-600 px-4">
          {subtitle}
        </p>
      </div>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="slide-up sticky top-28">
          <img 
            src={heroImage} 
            alt="Weronika Nowik" 
            class="w-full rounded-[2rem] shadow-xl"
          />
        </div>
        
        <div class="space-y-6 slide-up" style="animation-delay: 0.2s">
          <div class="prose prose-lg prose-pink text-gray-700 leading-relaxed max-w-none" set:html={content}></div>

          <div class="pt-8">
            <Button href="/kontakt">Porozmawiajmy</Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
