---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PocketBase from 'pocketbase';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'WebSite' | 'Service' | 'ProfilePage' | 'ContactPage' | 'AboutPage';
}

const { 
  title, 
  description = "Weronika Nowik - Doula, wsparcie okołoporodowe, konsultacje przedporodowe, grupy ciążowe.",
  image,
  type = 'WebSite'
} = Astro.props;

let colors = {
  primary: '#D85096',
  secondary: '#BEDBF4',
  dark: '#000000',
  light: '#ffffff'
};

try {
  const pb = new PocketBase('https://pocketbase.bieda.it');
  const settings = await pb.collection('site_settings').getList(1, 1);
  if (settings.items.length > 0) {
    const s = settings.items[0];
    colors.primary = s.color_primary || colors.primary;
    colors.secondary = s.color_secondary || colors.secondary;
    colors.dark = s.color_dark || colors.dark;
    colors.light = s.color_light || colors.light;
  }
} catch (e) {
  console.error("PocketBase connection error in Layout:", e.message);
}
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Weronika Nowik - Doula</title>
    <SEO title={title} description={description} image={image} type={type} />
    <style define:vars={{
      colorPrimary: colors.primary,
      colorSecondary: colors.secondary,
      colorDark: colors.dark,
      colorLight: colors.light
    }}>
      :root {
        --color-primary: var(--colorPrimary);
        --color-secondary: var(--colorSecondary);
        --color-dark: var(--colorDark);
        --color-light: var(--colorLight);
      }
    </style>
  </head>
  <body class="bg-secondary p-0 md:p-8 min-h-screen font-sans text-gray-900 selection:bg-primary/30">
    <div class="max-w-[1600px] mx-auto bg-gradient-to-b from-white via-white to-secondary/50 rounded-none md:rounded-[3rem] shadow-none md:shadow-2xl min-h-screen md:min-h-[calc(100vh-4rem)] flex flex-col relative border-none md:border md:border-white/50">
      <Header />
      <main class="flex-grow -mt-24 relative z-0">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
