---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  color?: string;
}

const { title, description, href, color = "bg-secondary/30" } = Astro.props;
---

<a href={href} class="block group">
  <div class={`h-full p-8 rounded-3xl ${color} transition-all duration-300 transform group-hover:-translate-y-2 hover:shadow-xl`}>
    <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center mb-6 shadow-sm text-primary">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
    </div>
    <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors">{title}</h3>
    <p class="text-gray-600 line-clamp-3">{description}</p>
    <div class="mt-6 flex items-center text-primary font-medium">
      <span>Dowiedz się więcej</span>
      <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
      </svg>
    </div>
  </div>
</a>
