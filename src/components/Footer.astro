---
import PocketBase from 'pocketbase';

const currentYear = new Date().getFullYear();

const pb = new PocketBase('https://pocketbase.bieda.it');
let settings = null;
try {
  const records = await pb.collection('site_settings').getList(1, 1);
  if (records.items.length > 0) settings = records.items[0];
} catch (e) {
  console.error("PocketBase connection error in Footer:", e.message);
}

const logo = settings?.logo_image ? `https://pocketbase.bieda.it/api/files/site_settings/${settings.id}/${settings.logo_image}` : "/logo-blue.png";
const description = settings?.footer_description || "Wsparcie okołoporodowe, konsultacje i grupy dla kobiet w ciąży. Razem w drodze do macierzyństwa.";
const phone = settings?.phone || "+48 123 456 789";
const email = settings?.email || "kontakt@weronikanowik.pl";
const ig = settings?.instagram_link || "#";
const fb = settings?.facebook_link || "#";
---

<footer class="bg-transparent pt-12 md:pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 mb-12 text-center md:text-left">
      <!-- Brand -->
      <div class="col-span-1 flex flex-col items-center md:items-start">
        <a href="/" class="mb-6 inline-block">
          <img src={logo} alt="Weronika Nowik Doula" class="h-24 md:h-32 lg:h-48 w-auto object-contain transition-opacity hover:opacity-80 mix-blend-multiply" />
        </a>
        <p class="text-gray-600 text-sm max-w-xs mt-2">
          {description}
        </p>
      </div>

      <!-- Links -->
      <div class="col-span-1">
        <h3 class="font-bold text-gray-900 mb-4">Szybkie linki</h3>
        <ul class="space-y-3 md:space-y-2">
          <li><a href="/o-mnie" class="text-gray-600 hover:text-primary transition-colors text-sm">O mnie</a></li>
          <li><a href="/#oferta" class="text-gray-600 hover:text-primary transition-colors text-sm">Moja oferta</a></li>
          <li><a href="/kontakt" class="text-gray-600 hover:text-primary transition-colors text-sm">Kontakt</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-span-1">
        <h3 class="font-bold text-gray-900 mb-4">Kontakt</h3>
        <ul class="space-y-3 md:space-y-2 text-sm text-gray-600">
          <li>Email: {email}</li>
          <li>Tel: {phone}</li>
          <li class="flex justify-center md:justify-start gap-4">
            <a href={ig} target="_blank" class="text-primary hover:underline">Instagram</a>
            <a href={fb} target="_blank" class="text-primary hover:underline">Facebook</a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-secondary/40 pt-8 flex flex-col md:flex-row justify-between items-center text-center md:text-left gap-4 md:gap-0">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Weronika Nowik. Wszelkie prawa zastrzeżone.
      </p>
      <p class="text-sm text-gray-400">
        Zaprojektowane z ❤️
      </p>
    </div>
  </div>
</footer>
